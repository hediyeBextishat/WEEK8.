class Flight:
    """Parent class representing a general flight."""
    
    def __init__(self, flight_number, origin, destination, departure_time):
        self.flight_number = flight_number
        self.origin = origin
        self.destination = destination
        self.departure_time = departure_time

    def display_flight_info(self):
        """Method to display core flight information."""
        print(f"Flight: {self.flight_number}")
        print(f"Route: {self.origin} to {self.destination}")
        print(f"Departure: {self.departure_time}")


class DomesticFlight(Flight):
    """Subclass representing a domestic flight (Inherits from Flight)."""
    
    def __init__(self, flight_number, origin, destination, departure_time, baggage_allowance):
        # Use super() to initialize attributes from the parent class
        super().__init__(flight_number, origin, destination, departure_time)
        # Specific attribute for domestic flights
        self.baggage_allowance = baggage_allowance

    def display_domestic_details(self):
        """Method specific to DomesticFlight."""
        # Accessing inherited method
        self.display_flight_info()
        print(f"Baggage Allowance: {self.baggage_allowance}kg")
        print("Note: Check-in opens 60 minutes before departure.")

# --- Example Usage ---

# Creating an instance of the subclass
nz_flight = DomesticFlight(
    flight_number="NZ888",
    origin="Auckland",
    destination="QUEENTOWN",
    departure_time="10:30 PM",
    baggage_allowance=2
)

# Calling the inherited method and the specific method
nz_flight.display_domestic_details()
